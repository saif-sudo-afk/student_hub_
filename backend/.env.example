# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email — use ONE of the two options below:
#
# Option A: Resend (needs a verified domain at resend.com/domains)
RESEND_API_KEY=re_your_resend_api_key
DEFAULT_FROM_EMAIL=Student Hub <noreply@yourdomain.com>
#
# Option B: Gmail SMTP (no custom domain needed)
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com/apppasswords → generate an App Password
#   3. Fill in the two vars below; leave RESEND_API_KEY empty
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=Student Hub <you@gmail.com>

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
