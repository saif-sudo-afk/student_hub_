{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.venv/**,.python312/**,.tmp/**,__pycache__/**,**/*.pyc,db.sqlite3,staticfiles/**,media/**}"
    }
  }
}
